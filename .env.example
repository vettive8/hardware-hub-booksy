# APP_ENV=production makes a real SECRET_KEY mandatory. A public demo is still production.
APP_ENV=development
SECRET_KEY=replace-me-in-production

# DEMO_MODE seeds the demo accounts and prefills the login form.
# Defaults to true outside production. Set explicitly to false on a real deployment.
DEMO_MODE=true

OPENROUTER_API_KEY=
OPENROUTER_DISABLED=0
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_FALLBACK_MODELS=google/gemini-3.1-flash-lite
